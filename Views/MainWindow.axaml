<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MonitorGUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="MonitorGUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Monitor de Processos: Visualização Mestre-Detalhe (Threads)"
        Background="#1E1E1E">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <!-- Header / Toolbar -->
        <Border Grid.Row="0" Background="#2D2D30" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="MONITOR DE PROCESSOS E THREADS" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Com Master-Detail em tempo real" FontSize="14" Foreground="#CCCCCC"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Tipo:" VerticalAlignment="Center" Foreground="White"/>
                    <ComboBox ItemsSource="{Binding OpcoesFiltro}" SelectedItem="{Binding FiltroSelecionado}" Width="130" Background="#3E3E42" Foreground="White" />
                    
                    <TextBlock Text="Limite:" VerticalAlignment="Center" Foreground="White" Margin="10,0,0,0"/>
                    <ComboBox ItemsSource="{Binding OpcoesLimite}" SelectedItem="{Binding LimiteSelecionado}" Width="80" Background="#3E3E42" Foreground="White"/>
                    
                    <TextBlock Text="Ciclo (ms):" VerticalAlignment="Center" Foreground="White" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding IntervalMs}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#42A5F5" Width="50"/>
                    <Button Command="{Binding DecreaseIntervalCommand}" Content="-" Width="30" HorizontalContentAlignment="Center"/>
                    <Button Command="{Binding IncreaseIntervalCommand}" Content="+" Width="30" HorizontalContentAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button Content="Iniciar Monitor" Command="{Binding StartMonitoringCommand}"
                            Background="#4CAF50" Foreground="White" FontWeight="Bold"
                            IsEnabled="{Binding !IsMonitoring}"/>
                    <Button Content="Pausar" Command="{Binding StopMonitoringCommand}"
                            Background="#F44336" Foreground="White" FontWeight="Bold"
                            IsEnabled="{Binding IsMonitoring}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content (Master-Detail) -->
        <Grid Grid.Row="1" RowDefinitions="*, 5, *">
            
            <!-- Process List (Master) -->
            <Border Grid.Row="0" Background="#252526" CornerRadius="8" Padding="10">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Text="LISTA DE PROCESSOS (Selecione um para ver as Threads)" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    
                    <!-- DataGrid Mestre -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Processos}" SelectedItem="{Binding ProcessoSelecionado}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="All" BorderThickness="1" BorderBrush="#333333">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID" Binding="{Binding Pid}" />
                            <DataGridTextColumn Header="Nome do Processo" Binding="{Binding Nome}" />
                            <DataGridTextColumn Header="Classificação" Binding="{Binding Classificacao}" />
                            <DataGridTextColumn Header="% CPU" Binding="{Binding PorcentagemCPU}" />
                            <DataGridTextColumn Header="Handles" Binding="{Binding HandleCount}" />
                            <DataGridTextColumn Header="Threads Qt." Binding="{Binding ThreadCount}" />
                            <DataGridTextColumn Header="Pri. Base" Binding="{Binding PrioridadeBase}" />
                            <DataGridTextColumn Header="Classe Prioridade" Binding="{Binding ClassePrioridade}" />
                            <DataGridTextColumn Header="Memória RAM" Binding="{Binding WorkingSetFormatado}" />
                            <DataGridTextColumn Header="Páginas(4K)" Binding="{Binding NumPaginas}" />
                            <DataGridTextColumn Header="Endereço V. Início" Binding="{Binding MemoriaInicio}" FontFamily="Monospace" />
                            <DataGridTextColumn Header="Endereço V. Fim" Binding="{Binding MemoriaFim}" FontFamily="Monospace" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- GridSplitter Flexível Central -->
            <GridSplitter Grid.Row="1" Background="#007ACC" ResizeDirection="Rows" ShowsPreview="True" Margin="0,2"/>

            <!-- Detail Section (Threads + Memory Map) -->
            <Grid Grid.Row="2" ColumnDefinitions="2*, 5, 1*">
                
                <!-- Thread List (Detail Left) -->
                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="10" BorderBrush="#333333" BorderThickness="1">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="THREADS DO PROCESSO: " FontSize="16" FontWeight="Bold" Foreground="#42A5F5"/>
                            <TextBlock Text="{Binding ProcessoSelecionado.Nome, TargetNullValue='(NENHUM SELECIONADO)'}" FontSize="16" FontWeight="Bold" Foreground="#FFCA28"/>
                            <TextBlock Text="{Binding ProcessoSelecionado.Pid, StringFormat=' [PID: {0}]', TargetNullValue=''}" FontSize="16" Foreground="#AAAAAA"/>
                        </StackPanel>
                        
                        <!-- DataGrid Detalhe -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ThreadsSelecionadas}" 
                                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                  GridLinesVisibility="All" BorderThickness="1" BorderBrush="#333333">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TID" Binding="{Binding Id}" />
                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" />
                                <DataGridTextColumn Header="Pri" Binding="{Binding Prioridade}" />
                                <DataGridTextColumn Header="Motivo UNIX" Binding="{Binding WaitReason}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- GridSplitter Vertical -->
                <GridSplitter Grid.Column="1" Background="#007ACC" ResizeDirection="Columns" Margin="2,0"/>

                <!-- Memory Map View (Detail Right) -->
                <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="8" Padding="10" BorderBrush="#333333" BorderThickness="1">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="MAPA DE MEMÓRIA SIMULADO" FontSize="14" FontWeight="Bold" Foreground="#66BB6A"/>
                            <TextBlock Text="(Distribuição RAM vs Swap)" FontSize="10" Foreground="#AAAAAA"/>
                        </StackPanel>
                        
                        <!-- ItemsControl rendered as WrapPanel for small squares -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MapaMemoriaSimulado}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel ItemWidth="18" ItemHeight="18" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="16" Height="16" Margin="1" 
                                                Background="{Binding CorHex}"
                                                ToolTip.Tip="{Binding ToolTip}"
                                                BorderBrush="#555555" BorderThickness="1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer / StatusBar -->
        <Border Grid.Row="2" Background="#007ACC" Padding="10,5" Margin="0,10,0,0" CornerRadius="5">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="SemiBold"/>
        </Border>
    </Grid>

</Window>
